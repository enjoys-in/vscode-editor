{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@full/*": ["src/full/*"],
      "@editor/*": ["src/full/*"],
      "@minimal/*": ["src/minimal/*"],
      "@plugins/*": ["src/plugins/*"],
      "@modules/*": ["src/modules/*"],
      "@ui/*": ["src/ui/*"]
    }
  },
  "include": ["src"]
}
